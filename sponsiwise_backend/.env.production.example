# ──────────────────────────────────────────────────────────────
# SponsiWise Backend — Production Environment Variables
# Copy to .env on your production server and fill in values.
# ──────────────────────────────────────────────────────────────

# Application
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://sponsiwise.app,https://www.sponsiwise.app

# Database (use connection pooling in production)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sponsiwise?sslmode=require"

# Redis
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password

# JWT Secrets (MUST be unique, min 48 bytes, generated with: openssl rand -base64 48)
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_REFRESH_EXPIRES_IN=7d

# S3 / Object Storage (AWS S3 or MinIO)
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY=your-access-key-id
S3_SECRET_KEY=your-secret-access-key
S3_BUCKET=sponsiwise
S3_REGION=us-east-1
S3_PUBLIC_URL=https://sponsiwise.s3.amazonaws.com

# Resend Email Service
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=SponsiWise <noreply@sponsiwise.app>
