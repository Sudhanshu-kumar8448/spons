// ============================================
// AUTH MODELS
// ============================================

model User {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String?  @map("company_id") @db.Uuid
  organizerId String?  @map("organizer_id") @db.Uuid
  email       String   @unique
  password    String // Stored hashed (bcrypt/argon2)
  role        Role     @default(USER)
  isActive    Boolean  @default(true) @map("is_active")

  // Email verification
  emailVerified              Boolean   @default(false) @map("email_verified")
  emailVerificationToken     String?   @map("email_verification_token") // SHA-256 hash
  emailVerificationExpiry    DateTime? @map("email_verification_expiry")
  emailVerificationSentCount Int       @default(0) @map("email_verification_sent_count")
  emailVerificationLastSentAt DateTime? @map("email_verification_last_sent_at")

  // Password reset
  passwordResetToken  String?   @map("password_reset_token") // SHA-256 hash
  passwordResetExpiry DateTime? @map("password_reset_expiry")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  company        Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  organizer      Organizer?     @relation(fields: [organizerId], references: [id], onDelete: SetNull)
  refreshTokens  RefreshToken[]
  notifications  Notification[]
  eventsApproved Event[]        @relation("EventApprovedBy")

  companiesApproved          Company[]         @relation("CompanyApprovedBy")
  proposalsOrganizerApproved Proposal[]        @relation("ProposalOrganizerApprovedBy")
  proposalsReviewed          Proposal[]        @relation("ProposalReviewedBy")
  proposalMessagesSent       ProposalMessage[]

  // Indexes
  @@index([email])
  @@index([companyId])
  @@index([organizerId])
  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @map("token_hash") // Stored hashed (sha256)
  deviceInfo String?   @map("device_info") // Optional: browser, device name
  isRevoked  Boolean   @default(false) @map("is_revoked")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  rotatedAt  DateTime? @map("rotated_at") // Set when token is rotated

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// COMPANY MODEL
// ============================================

model Company {
  id                 String             @id @default(uuid()) @db.Uuid
  name               String             @db.VarChar(255)
  slug               String?            @unique @db.VarChar(255)
  type               CompanyType
  website            String?            @db.VarChar(500)
  strategicIntent    String?            @db.Text
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  // Approval tracking fields
  approvedById    String?   @map("approved_by_id") @db.Uuid
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason") @db.Text

  // Relations
  users        User[]
  sponsorships Sponsorship[]

  approvedBy User? @relation("CompanyApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  // Indexes
  @@index([type])
  @@index([verificationStatus])
  @@index([slug])
  @@index([approvedById])
  @@map("companies")
}

// ============================================
// ORGANIZER MODEL (domain entity — manages events)
// ============================================

model Organizer {
  id           String        @id @default(uuid()) @db.Uuid
  name         String        @db.VarChar(255)
  type         OrganizerType @default(INDIVIDUAL)
  pastRecords  String?       @db.Text
  socialLinks  Json?         @map("social_links") @db.JsonB // e.g. { "twitter": "url", "linkedin": "url" }
  taxId        String?       @map("tax_id") @db.VarChar(100)
  contactPhone String?       @map("contact_phone") @db.VarChar(50)
  website      String?       @db.VarChar(500)
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  // Relations
  events Event[]
  users  User[]

  // Indexes
  @@index([isActive])
  @@index([type])
  @@map("organizers")
}

// ============================================
// EVENT MODEL (domain entity — owned by Organizer)
// ============================================

model Event {
  id                 String             @id @default(uuid()) @db.Uuid
  organizerId        String             @map("organizer_id") @db.Uuid
  title              String             @db.VarChar(255)
  description        String?            @db.Text
  expectedFootfall   Int                @default(0) @map("expected_footfall")
  startDate          DateTime           @map("start_date")
  endDate            DateTime           @map("end_date")
  status             EventStatus        @default(DRAFT)
  website            String?            @db.VarChar(500)
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  isActive           Boolean            @default(true) @map("is_active")

  // New fields for sponsorship inventory
  category     EventCategory @map("category")
  edition      EventEdition  @map("edition")
  pptDeckUrl   String?       @map("ppt_deck_url") @db.VarChar(500)
  contactPhone String?       @map("contact_phone") @db.VarChar(50)
  contactEmail String?       @map("contact_email") @db.VarChar(255)

  // Approval tracking fields
  approvedById    String?   @map("approved_by_id") @db.Uuid
  approvedAt      DateTime? @map("approved_at")
  rejectionReason String?   @map("rejection_reason") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organizer       Organizer             @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  sponsorships    Sponsorship[]
  tiers           SponsorshipTier[]
  address         Address?
  audienceProfile EventAudienceProfile?
  approvedBy      User?                 @relation("EventApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  // Indexes
  @@index([organizerId])
  @@index([status])
  @@index([organizerId, status])
  @@index([verificationStatus])
  @@index([isActive, status, verificationStatus])
  @@index([approvedById])
  @@map("events")
}

// ============================================
// ADDRESS MODEL (NEW - for structured event location)
// ============================================

model Address {
  id           String   @id @default(uuid()) @db.Uuid
  eventId      String   @unique @map("event_id") @db.Uuid
  addressLine1 String   @map("address_line_1") @db.VarChar(255)
  addressLine2 String?  @map("address_line_2") @db.VarChar(255)
  city         String   @db.VarChar(100)
  state        String   @db.VarChar(100)
  country      String   @db.VarChar(100)
  postalCode   String   @map("postal_code") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ============================================
// SPONSORSHIP TIER MODEL (NEW - inventory layer)
// ============================================

model SponsorshipTier {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  tierType    TierType
  customName  String?  @map("custom_name") @db.VarChar(255)
  askingPrice Decimal  @map("asking_price") @db.Decimal(12, 2)
  totalSlots  Int      @default(1) @map("total_slots")
  soldSlots   Int      @default(0) @map("sold_slots")
  isLocked    Boolean  @default(false) @map("is_locked")
  isActive    Boolean  @default(true) @map("is_active")
  // Benefits stored as JSON string - parsed at application level
  benefits    String   @default("[]") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  event             Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  proposals         Proposal[]
  deliverableForm   TierDeliverableForm?

  // NOTE: Unique constraint removed. Predefined tiers uniqueness is enforced in service layer.
  // CUSTOM tierType allows multiple tiers per event.

  // Indexes
  @@index([eventId])
  @@index([isLocked])
  @@index([tierType])
  @@map("sponsorship_tiers")
}

// ============================================
// ATTENDEES PROFILE MODEL (Event -> EventAudienceProfile link)
// ============================================

model EventAudienceProfile {
  id      String @id @default(uuid()) @db.Uuid
  eventId String @unique @map("event_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  genders AudienceGender[]
  ages    AudienceAgeGroup[]
  incomes AudienceIncomeGroup[]
  regions AudienceRegionDistribution[]

  @@map("event_audience_profiles")
}

// Gender Distribution
enum GenderType {
  MALE
  FEMALE
  OTHER
}

model AudienceGender {
  id         String     @id @default(uuid()) @db.Uuid
  profileId  String     @map("profile_id") @db.Uuid
  gender     GenderType
  percentage Float

  profile EventAudienceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, gender])
  @@map("audience_genders")
}

// Age Distribution
enum AgeBracket {
  AGE_5_12
  AGE_12_17
  AGE_17_28
  AGE_28_45
  AGE_45_PLUS
}

model AudienceAgeGroup {
  id         String     @id @default(uuid()) @db.Uuid
  profileId  String     @map("profile_id") @db.Uuid
  bracket    AgeBracket
  percentage Float

  profile EventAudienceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, bracket])
  @@map("audience_age_groups")
}

//Income Distribution
enum IncomeBracket {
  BELOW_10L
  BETWEEN_10L_25L
  BETWEEN_25L_50L
  BETWEEN_50L_1CR
  ABOVE_1CR
}

model AudienceIncomeGroup {
  id         String        @id @default(uuid()) @db.Uuid
  profileId  String        @map("profile_id") @db.Uuid
  bracket    IncomeBracket
  percentage Float

  profile EventAudienceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, bracket])
  @@map("audience_income_groups")
}

//Region Distribution (State/UT + Country)
model AudienceRegionDistribution {
  id         String @id @default(uuid()) @db.Uuid
  profileId  String @map("profile_id") @db.Uuid
  stateOrUT  String @map("state_or_ut") @db.VarChar(100)
  country    String @db.VarChar(100)
  percentage Float

  profile EventAudienceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("audience_regions")
}

// ============================================
// SPONSORSHIP MODEL (Company ↔ Event link)
// ============================================

model Sponsorship {
  id        String            @id @default(uuid()) @db.Uuid
  companyId String            @map("company_id") @db.Uuid
  eventId   String            @map("event_id") @db.Uuid
  status    SponsorshipStatus @default(PENDING)
  tier      String?           @db.VarChar(100)
  notes     String?           @db.Text
  isActive  Boolean           @default(true) @map("is_active")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  // Relations
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  proposals Proposal[]

  // Unique constraint: one sponsorship per company–event pair
  @@unique([companyId, eventId])
  // Indexes
  @@index([companyId])
  @@index([eventId])
  @@index([status])
  @@index([isActive])
  @@map("sponsorships")
}

// ============================================
// PROPOSAL MODEL (workflow entity — negotiation / approval)
// ============================================

model Proposal {
  id             String         @id @default(uuid()) @db.Uuid
  sponsorshipId  String         @map("sponsorship_id") @db.Uuid
  tierId         String?        @map("tier_id") @db.Uuid
  status         ProposalStatus @default(DRAFT)
  proposedTier   String?        @map("proposed_tier") @db.VarChar(100)
  proposedAmount Decimal?       @map("proposed_amount") @db.Decimal(12, 2)
  message        String?        @db.Text
  notes          String?        @db.Text
  submittedAt    DateTime?      @map("submitted_at")
  reviewedAt     DateTime?      @map("reviewed_at")

  // Manager review tracking
  reviewedById      String? @map("reviewed_by_id") @db.Uuid
  reviewedByRole    Role?   @map("reviewed_by_role")
  managerReviewNote String? @map("manager_review_note") @db.Text

  // Organizer approval tracking
  organizerApprovalStatus OrganizerApprovalStatus @default(PENDING) @map("organizer_approval_status")
  organizerApprovedById   String?                 @map("organizer_approved_by_id") @db.Uuid
  organizerApprovedAt     DateTime?               @map("organizer_approved_at")
  organizerRejectionNote  String?                 @map("organizer_rejection_note") @db.Text

  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  sponsorship         Sponsorship       @relation(fields: [sponsorshipId], references: [id], onDelete: Cascade)
  tier                SponsorshipTier?  @relation(fields: [tierId], references: [id], onDelete: SetNull)
  organizerApprovedBy User?             @relation("ProposalOrganizerApprovedBy", fields: [organizerApprovedById], references: [id], onDelete: SetNull)
  reviewedBy          User?             @relation("ProposalReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  messages            ProposalMessage[]

  // Indexes
  @@index([sponsorshipId])
  @@index([tierId])
  @@index([status])
  @@index([sponsorshipId, status])
  @@index([reviewedById])
  @@map("proposals")
}

model ProposalMessage {
  id         String   @id @default(uuid()) @db.Uuid
  proposalId String   @map("proposal_id") @db.Uuid
  senderId   String   @map("sender_id") @db.Uuid
  senderRole Role     @map("sender_role")
  message    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  proposal Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  sender   User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([senderId])
  @@map("proposal_messages")
}

// ============================================
// AUDIT LOG MODEL (append-only system log)
// ============================================

model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  // Who performed the action
  actorId   String @map("actor_id") @db.Uuid
  actorRole String @map("actor_role") @db.VarChar(50)

  // What happened
  action String @db.VarChar(100) // e.g. "proposal.created", "proposal.status_changed"

  // Which entity was affected
  entityType String @map("entity_type") @db.VarChar(50) // e.g. "Proposal", "Sponsorship"
  entityId   String @map("entity_id") @db.Uuid

  // Arbitrary JSON payload (old/new values, context, etc.)
  metadata Json? @default("{}") @db.JsonB

  // Immutable timestamp
  createdAt DateTime @default(now()) @map("created_at")

  // Indexes for efficient querying
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// EMAIL LOG MODEL (delivery tracking)
// ============================================

model EmailLog {
  id           String      @id @default(uuid()) @db.Uuid
  recipient    String      @db.VarChar(255)
  subject      String      @db.VarChar(500)
  jobName      String      @map("job_name") @db.VarChar(100)
  entityType   String?     @map("entity_type") @db.VarChar(50)
  entityId     String?     @map("entity_id") @db.Uuid
  status       EmailStatus
  errorMessage String?     @map("error_message") @db.Text
  createdAt    DateTime    @default(now()) @map("created_at")

  // Indexes
  @@index([jobName])
  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

// ============================================
// DELIVERABLE ENUMS
// ============================================

enum DeliverableCategory {
  PHYSICAL
  DIGITAL
}

enum BrandingType {
  EXCLUSIVE
  MULTI
}

enum DeliverableUnit {
  POSTS
  PIECES
  BOARDS
  DAYS
  HOURS
  MINUTES
  SESSIONS
  BANNERS
  PAGES
  SCREENS
  SPOTS
  OTHER
}

enum DeliverableFormStatus {
  DRAFT
  SENT_TO_ORGANIZER
  FILLED
  SUBMITTED
}

// ============================================
// TIER DELIVERABLE FORM (1-to-1 with SponsorshipTier)
// ============================================

model TierDeliverableForm {
  id        String                @id @default(uuid()) @db.Uuid
  tierId    String                @unique @map("tier_id") @db.Uuid
  status    DeliverableFormStatus @default(DRAFT)
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")

  // Relations
  tier SponsorshipTier    @relation(fields: [tierId], references: [id], onDelete: Cascade)
  rows TierDeliverableRow[]

  @@index([tierId])
  @@index([status])
  @@map("tier_deliverable_forms")
}

// ============================================
// TIER DELIVERABLE ROW (each row in the form)
// ============================================

model TierDeliverableRow {
  id              String              @id @default(uuid()) @db.Uuid
  formId          String              @map("form_id") @db.Uuid
  category        DeliverableCategory
  deliverableName String              @map("deliverable_name") @db.VarChar(500)
  brandingType    BrandingType        @map("branding_type")
  quantity        Int                 @default(0)
  unit            DeliverableUnit     @default(PIECES)
  otherUnit       String?             @map("other_unit") @db.VarChar(100)
  remarks         String?             @db.Text
  sortOrder       Int                 @default(0) @map("sort_order")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  // Relations
  form TierDeliverableForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([formId, sortOrder])
  @@map("tier_deliverable_rows")
}

// ============================================
// DELIVERABLE TEMPLATE (global, reusable by any manager)
// ============================================

model DeliverableTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  rows        Json     @default("[]") @db.JsonB // Array of { category, deliverableName, brandingType, quantity, unit, otherUnit, remarks }
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([name])
  @@map("deliverable_templates")
}

// ============================================
// NOTIFICATION MODEL
// ============================================

model Notification {
  id         String               @id @default(uuid()) @db.Uuid
  userId     String               @map("user_id") @db.Uuid
  title      String               @db.VarChar(255)
  message    String               @db.Text
  severity   NotificationSeverity @default(INFO)
  read       Boolean              @default(false)
  link       String?              @db.VarChar(512)
  entityType String?              @map("entity_type") @db.VarChar(50)
  entityId   String?              @map("entity_id") @db.Uuid
  createdAt  DateTime             @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}
